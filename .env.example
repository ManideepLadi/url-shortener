APP_NAME=url-shortener
APP_ENV=development
LOG_LEVEL=INFO

# DigitalOcean Managed PostgreSQL
# sslmode=require in URL is auto-stripped; SSL handled via DATABASE_SSL_REQUIRED=true
DATABASE_URL=postgresql+asyncpg://db-dev:YOUR_PASSWORD@YOUR_HOST:25060/db-dev
DATABASE_SSL_REQUIRED=true
# true = verify-full (production). false = encrypt only, no CA file needed (local dev).
DATABASE_SSL_VERIFY_CA=false

# Required when DATABASE_SSL_VERIFY_CA=true. Download from DO → Connection Details.
# App Platform: DATABASE_CA_CERT=${defaultdb.CA_CERT}
DATABASE_CA_CERT=

BASE_URL=http://localhost:8000
DEFAULT_LINK_TTL_SECONDS=
MAX_LINK_TTL_SECONDS=31536000
REDIRECT_CACHE_TTL_SECONDS=3600
AUTO_ALIAS_STRATEGY=random
AUTO_ALIAS_LENGTH=8
AUTO_ALIAS_MAX_RETRIES=5
DB_INIT_MAX_RETRIES=10
DB_INIT_RETRY_DELAY_SECONDS=2.0
METRICS_ENABLED=true
