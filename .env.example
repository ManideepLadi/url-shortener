APP_NAME=url-shortener
APP_ENV=development
LOG_LEVEL=INFO

# DigitalOcean Managed PostgreSQL
DATABASE_URL=postgresql+asyncpg://db-dev:YOUR_PASSWORD@app-805eb9fc-112f-420e-94ca-82bf1d0ccae6-do-user-38342133-0.a.db.ondigitalocean.com:25060/db-dev
DATABASE_SSL_REQUIRED=true

# Redis disabled for now
# REDIS_URL=redis://localhost:6379/0

BASE_URL=http://localhost:8000
REDIRECT_CACHE_TTL_SECONDS=3600
AUTO_ALIAS_LENGTH=8
AUTO_ALIAS_MAX_RETRIES=5
DB_INIT_MAX_RETRIES=10
DB_INIT_RETRY_DELAY_SECONDS=2.0
